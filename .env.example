# ============================================================
# Kiro Honcho 环境变量配置（唯一配置文件）
# 复制此文件为 .env 并填写实际值: cp .env.example .env
# ============================================================

# ===== 安全密钥（生产环境必须更换） =====
JWT_SECRET_KEY=change-me-to-a-strong-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# AWS 凭证加密密钥（base64 编码的 32 字节）
# 生成方式: python -c "import secrets, base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
APP_ENCRYPTION_KEY=Ce0bCS9X70FOrfaHkp48e0UaCmRvPibSf1oKVjf41s8=

# ===== 数据库配置 =====
# DB_TYPE: sqlite 或 mysql
DB_TYPE=sqlite

# --- SQLite（默认，数据存储在 ./data 目录） ---
# SQLITE_PATH=/app/data/kiro_honcho.db

# --- MySQL（DB_TYPE=mysql 时取消注释并填写） ---
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=your-password
# MYSQL_DATABASE=kiro_honcho
# DB_SSL_CA=global-bundle.pem

# ===== CORS（逗号分隔，生产环境改为实际域名） =====
# CORS_ORIGINS=*
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ===== 默认管理员账号 =====
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123

# ===== AWS 默认区域 =====
DEFAULT_SSO_REGION=us-east-2
DEFAULT_KIRO_REGION=us-east-1

# ===== 其他 =====
# 自动订阅检查间隔（分钟），0 表示不检查
AUTO_SUBSCRIBE_CHECK_INTERVAL=5
