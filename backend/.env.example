# Kiro Honcho Backend Configuration

# Application
APP_NAME=Kiro Honcho
APP_ENV=development
APP_SECRET_KEY=your-secret-key-here-change-in-production

# Encryption key for AWS credentials (base64 encoded 32-byte key)
# Generate with: python -c "import secrets, base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
APP_ENCRYPTION_KEY=

# Database
DATABASE_URL=sqlite+aiosqlite:///./kiro_honcho.db
# For PostgreSQL: postgresql+asyncpg://user:password@localhost:5432/kiro_honcho

# JWT Authentication
JWT_SECRET_KEY=your-jwt-secret-key-here-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# AWS Default Regions
DEFAULT_SSO_REGION=us-east-2
DEFAULT_KIRO_REGION=us-east-1

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
